# AlphaHunter AI — environment configuration (copy to .env)
# No secrets are hardcoded anywhere in the codebase; everything comes from here.

# --- App ---
ALPHAHUNTER_ENV=development
LOG_LEVEL=INFO

# --- Screener thresholds (override the spec defaults if desired) ---
REVENUE_FLOOR=1000000000
DAY_DROP_PCT=-5.0
MONTH_DROP_PCT=-20.0
RSI_MAX=35.0
VOLUME_SPIKE_RATIO=1.5
INSTITUTIONAL_OWNERSHIP_MIN=0.50

# Risk / catalyst awareness
EARNINGS_WINDOW_DAYS=7
HIGH_SHORT_INTEREST=0.10
NEAR_52W_LOW_PCT=8.0

# --- Composite AI score weights (must sum to 1.0) ---
WEIGHT_TECHNICAL=0.35
WEIGHT_FUNDAMENTAL=0.25
WEIGHT_OPTIONS=0.20
WEIGHT_MOMENTUM=0.10
WEIGHT_SENTIMENT=0.10

# --- Data / caching ---
CACHE_TTL_SECONDS=900
MAX_UNIVERSE=0          # 0 = no cap; set e.g. 300 for fast local runs
REQUEST_SLEEP=0.3       # politeness delay between tickers (seconds)

# --- Infrastructure (optional; app runs without these) ---
DATABASE_URL=postgresql+psycopg://alphahunter:alphahunter@localhost:5432/alphahunter
REDIS_URL=redis://localhost:6379/0

# --- Optional LLM explanation layer ---
# OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Alerts (optional) ---
# SLACK_WEBHOOK_URL=
# DISCORD_WEBHOOK_URL=
# ALERT_EMAIL_TO=

# CSP-on-dip signal
CSP_DIP_DAY_PCT=-2.0
CSP_MIN_HIST_WIN=0.55
CSP_MIN_UPSIDE=10.0

# Position sizing & risk/reward gates
ACCOUNT_SIZE=25000
MAX_RISK_PCT=1.0
MIN_RISK_REWARD=1.5

# Opportunity scan (keeps the Opportunities board populated in calm markets)
OPP_MONTH_DROP=-8.0
OPP_WEEK_DROP=-6.0
OPP_RSI_MAX=42.0
OPP_MAX_SCORED=40
OPP_MIN_RESULTS=15
